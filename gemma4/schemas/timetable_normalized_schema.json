{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TimetableNormalizedPayload",
  "type": "object",
  "required": [
    "version",
    "timezone",
    "semester_label",
    "entries",
    "warnings"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "timezone": {
      "type": "string"
    },
    "semester_label": {
      "type": [
        "string",
        "null"
      ]
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "title",
          "course_code",
          "section",
          "days",
          "start_time",
          "end_time",
          "location",
          "instructor",
          "delivery_mode",
          "weeks",
          "notes",
          "source_text"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "course_code": {
            "type": [
              "string",
              "null"
            ]
          },
          "section": {
            "type": [
              "string",
              "null"
            ]
          },
          "days": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "MON",
                "TUE",
                "WED",
                "THU",
                "FRI",
                "SAT",
                "SUN"
              ]
            },
            "minItems": 1
          },
          "start_time": {
            "type": [
              "string",
              "null"
            ],
            "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$"
          },
          "end_time": {
            "type": [
              "string",
              "null"
            ],
            "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$"
          },
          "location": {
            "type": [
              "string",
              "null"
            ]
          },
          "instructor": {
            "type": [
              "string",
              "null"
            ]
          },
          "delivery_mode": {
            "type": "string",
            "enum": [
              "offline",
              "online",
              "hybrid",
              "unknown"
            ]
          },
          "weeks": {
            "type": "string",
            "enum": [
              "ALL",
              "ODD",
              "EVEN",
              "CUSTOM",
              "UNKNOWN"
            ]
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "source_text": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "source_text",
          "reason"
        ],
        "properties": {
          "source_text": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

