# Runtime mode. Use local for development; Cloud Run closed beta must set beta.
APP_RELEASE_MODE=local
# Optional fail-closed guard for any non-Cloud-Run deployment that must behave
# like beta/production even if APP_RELEASE_MODE is accidentally left local.
APP_REQUIRE_SAFE_RUNTIME=false

# Database
POSTGRES_DB=timetable
POSTGRES_USER=timetable
POSTGRES_PASSWORD=change-me
# Spring Boot beta/runtime database. Closed beta must use PostgreSQL/Cloud SQL;
# do not rely on the application.properties H2 fallback outside local dev.
APP_DB_URL=jdbc:postgresql://localhost:5432/timetable
APP_DB_USERNAME=timetable
APP_DB_PASSWORD=change-me

# Public app URLs
APP_FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api
APP_SESSION_TIMEOUT=4h

# Local/demo-only switches.
# Keep these false for service/production deployments.
APP_AUTH_MOCK_LOGIN_ENABLED=false
APP_SYNC_GOOGLE_MOCK_ENABLED=false

# Google OAuth.
# Local dev may provide GOOGLE_CLIENT_ID/GOOGLE_CLIENT_SECRET or mount a client
# secret JSON file. Cloud Run beta should use Secret Manager pinned versions and
# keep client_secret_*.json outside the repo/deploy context.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CREDENTIALS_FILE=

# AI assistant
APP_AI_ENABLED=false
APP_AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
APP_GEMINI_API_KEY=
APP_AI_MODEL=gemini-2.5-flash
APP_AI_MAX_TOKENS=768
APP_AI_TEMPERATURE=0.0
APP_AI_TIMEOUT_SECONDS=8
